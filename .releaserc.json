{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "pnpm --filter @opennbs/nbsvis version ${nextRelease.version} --git-tag-version=false",
        "publishCmd": "pnpm --filter @opennbs/nbsvis publish --access public --no-git-checks"
      }
    ],
    [
      "@semantic-release/github",
      {
        "labels": []
      }
    ]
  ]
}
