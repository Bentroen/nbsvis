{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "cd packages/nbsvis && pnpm version ${nextRelease.version} --no-git-tag-version --allow-same-version",
        "publishCmd": "cd packages/nbsvis && pnpm publish --no-git-checks"
      }
    ],
    [
      "@semantic-release/github",
      {
        "labels": []
      }
    ]
  ]
}
